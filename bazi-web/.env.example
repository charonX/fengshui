# Anthropic API Key
# 火山引擎 Ark API Key / 阿里云 DashScope API Key: https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
ANTHROPIC_API_KEY=sk-your-api-key-here

# Anthropic Base URL
# 火山引擎 Ark API / 阿里云 DashScope 兼容接口
ANTHROPIC_BASE_URL=https://ark.cn-beijing.volces.com/api/v3 # 或 https://coding.dashscope.aliyuncs.com/apps/anthropic 等

# Anthropic Model
# 支持的模型例如：claude-3-5-sonnet-20241022, qwen3.5-plus 等
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ========== Email & SMTP Settings (Used for Forgot Password) ==========
# Configure your SMTP server details to enable actual email sending.
# E.g. for QQ Mail: smtp.qq.com, port 465
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=your-email@example.com
SMTP_PASS=your-smtp-password-or-auth-code
SMTP_FROM=your-email@example.com
